# OpenAI API（ChatGPT LLM + 埋め込みベクトル）
# https://platform.openai.com/ でAPIキーを取得
OPENAI_API_KEY=your_openai_api_key_here

# Ollama（ローカルLLM）※後でローカルAI移行時に再び使用
# NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
# NEXT_PUBLIC_MODEL_NAME=gemma4

# Aivis Cloud API
# ダッシュボード: https://api.aivis-project.com
AIVIS_API_KEY=your_api_key_here

# AivisHub のモデルUUID（必須）
# 例: https://hub.aivis-project.com/models/{uuid}
NEXT_PUBLIC_AIVIS_MODEL_UUID=a59cb814-0083-4369-8542-f51a29e72af7

# 複数話者モデルのみ必要。単一話者モデルなら空欄でOK
NEXT_PUBLIC_AIVIS_SPEAKER_UUID=

# チャート計算エンジン（Pythonサービス）
# python/ フォルダで uvicorn main:app を起動してから使用
CHART_API_URL=http://localhost:8000

# GeoNames API（都市名→座標変換・無料アカウント必要）
# https://www.geonames.org/ で登録
GEONAMES_USERNAME=your_geonames_username
